# Copy to .env and fill in your Confluent Cloud values. .env is gitignored —
# never commit real credentials.

# --- Confluent Cloud: Kafka cluster ---
# Cluster settings → Bootstrap server (host:9092, no protocol prefix)
CC_BOOTSTRAP=pkc-xxxxx.<region>.<cloud>.confluent.cloud:9092
# A Kafka API key/secret for the cluster (needs permission to create/produce/consume topics)
CC_API_KEY=your-kafka-api-key
CC_API_SECRET=your-kafka-api-secret

# --- Confluent Cloud: Schema Registry (Stream Governance) ---
# Environment → Stream Governance API → Endpoint
CC_SR_URL=https://psrc-xxxxx.<region>.<cloud>.confluent.cloud
# A Schema Registry API key/secret (separate from the Kafka key)
CC_SR_API_KEY=your-sr-api-key
CC_SR_API_SECRET=your-sr-api-secret
